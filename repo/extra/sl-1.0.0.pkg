   |/-=|___|=    ||    ||    ||    |_____/~\___/        
    \_/      \__/  \__/  \__/  \__/      \_/            
]],
}
for step = 1, 30 do
  term.clear()
  local pad = string.rep(" ", math.max(0, W - 60 - step))
  local f = frames[(step % 2) + 1]
  for line in (f .. "\n"):gmatch("([^\n]*)\n") do
    term.write(pad .. line .. "\n")
  end
  k.event.pull(0.10)
end
term.clear()
return 0
]],
